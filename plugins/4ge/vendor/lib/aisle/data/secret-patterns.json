{
  "version": "1.0.1",
  "description": "Credential detection patterns. Merged from secret-guard.cjs (13) + token-guard.cjs (5) = 18 unique. ghs_ removed (not in source hooks), bearer-any added from token-guard.",
  "patterns": [
    { "id": "openai-key", "regex": "sk-[a-zA-Z0-9]{20,}", "label": "OpenAI/Anthropic API key", "source": "secret-guard" },
    { "id": "openai-proj", "regex": "sk-proj-[a-zA-Z0-9_-]{20,}", "label": "OpenAI project API key", "source": "secret-guard" },
    { "id": "anthropic-key", "regex": "sk-ant-[a-zA-Z0-9-]{20,}", "label": "Anthropic API key", "source": "secret-guard" },
    { "id": "github-pat", "regex": "ghp_[a-zA-Z0-9]{36,}", "label": "GitHub PAT", "source": "secret-guard" },
    { "id": "github-finegrained", "regex": "github_pat_[a-zA-Z0-9_]{20,}", "label": "GitHub fine-grained PAT", "source": "secret-guard" },
    { "id": "github-oauth", "regex": "gho_[a-zA-Z0-9]{36}", "label": "GitHub OAuth token", "source": "token-guard" },
    { "id": "aws-akia", "regex": "AKIA[A-Z0-9]{16}", "label": "AWS access key", "source": "secret-guard" },
    { "id": "slack-token", "regex": "xox[bpsa]-[a-zA-Z0-9-]+", "label": "Slack token", "source": "secret-guard" },
    { "id": "private-key", "regex": "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----", "label": "Private key", "source": "secret-guard" },
    { "id": "bearer-jwt", "regex": "Bearer\\s+ey[a-zA-Z0-9._-]{20,}", "label": "Bearer JWT token", "source": "secret-guard" },
    { "id": "bearer-any", "regex": "Bearer\\s+[A-Za-z0-9\\-._~+/]{20,}=*", "label": "Bearer token (general)", "source": "token-guard" },
    { "id": "discord-token", "regex": "[a-zA-Z0-9]{24}\\.[a-zA-Z0-9]{6}\\.[a-zA-Z0-9_-]{27,}", "label": "Discord token", "source": "secret-guard" },
    { "id": "azure-storage", "regex": "DefaultEndpointsProtocol=https;AccountName=", "label": "Azure Storage connection string", "source": "secret-guard" },
    { "id": "azure-key", "regex": "AccountKey=[a-zA-Z0-9+/]{80,}==", "label": "Azure Storage account key", "source": "secret-guard" },
    { "id": "azure-sas", "regex": "SharedAccessSignature=sv=", "label": "Azure SAS token", "source": "secret-guard" },
    { "id": "stripe-live", "regex": "sk_live_[a-zA-Z0-9]{24,}", "label": "Stripe live secret key", "source": "aisle-spec" },
    { "id": "cred-in-url", "regex": "://[^\\s:/?#]+:[^\\s@/?#]+@", "label": "Credentials in URL", "source": "aisle-spec" },
    { "id": "session-hex", "regex": "session_[a-f0-9]{32,}", "label": "Session token", "source": "token-guard" },
    { "id": "gcp-service-account", "regex": "\"type\"\\s*:\\s*\"service_account\"[\\s\\S]{0,64}\"private_key\"\\s*:", "label": "GCP service account key", "source": "risk-research" },
    { "id": "supabase-key", "regex": "(anon|service_role)\\s*(key|=|:)\\s*[\"']?eyJ[a-zA-Z0-9._-]{20,}", "label": "Supabase anon/service_role key", "source": "risk-research" },
    { "id": "cloudflare-api-token", "regex": "CLOUDFLARE[_.]?(API[_.]?TOKEN|API[_.]?KEY|ACCESS[_.]?SECRET)\\s*[=:]\\s*[\"']?[a-zA-Z0-9_-]{37,}", "label": "Cloudflare API token/key", "source": "risk-research" },
    { "id": "db-connection-string", "regex": "(postgres|mysql|mongodb(\\+srv)?|redis|mariadb)://[^\\s:/?#]+:[^\\s@/?#]+@", "label": "Database connection string with credentials", "source": "risk-research" }
  ]
}
