{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aisle-config.schema.json",
  "title": "AISLE Config",
  "description": "Configuration schema for the AISLE security capability.",
  "type": "object",
  "required": ["version", "stateDir", "tiers"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "description": "Semver string. Updated when AISLE logic changes.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "stateDir": {
      "type": "string",
      "description": "Absolute path to AISLE state directory. Must be within os.homedir().",
      "minLength": 1
    },
    "tiers": {
      "type": "object",
      "description": "Per-scanner tier overrides. Keys A-I map to scanner IDs.",
      "required": ["A", "B", "C", "D", "E", "F", "G", "H", "I"],
      "additionalProperties": false,
      "properties": {
        "A": { "$ref": "#/definitions/tier" },
        "B": { "$ref": "#/definitions/tier" },
        "C": { "$ref": "#/definitions/tier" },
        "D": { "$ref": "#/definitions/tier" },
        "E": { "$ref": "#/definitions/tier" },
        "F": { "$ref": "#/definitions/tier" },
        "G": { "$ref": "#/definitions/tier" },
        "H": { "$ref": "#/definitions/tier" },
        "I": { "$ref": "#/definitions/tier" }
      }
    },
    "egressAllowlist": {
      "type": "array",
      "description": "Hostnames permitted for outbound network access.",
      "items": { "type": "string" }
    },
    "exceptions": {
      "type": "array",
      "description": "Documented exceptions to scanner findings.",
      "items": { "$ref": "#/definitions/exception" }
    },
    "alerting": {
      "type": "object",
      "description": "Alerting threshold configuration.",
      "properties": {
        "blockThreshold": { "type": "integer", "minimum": 0 },
        "warnThreshold": { "type": "integer", "minimum": 0 },
        "healthCheckInterval": { "type": "integer", "minimum": 0 }
      }
    },
    "threatIntel": {
      "type": "object",
      "description": "Threat intelligence refresh and API configuration.",
      "properties": {
        "osvRefreshTTL": { "type": "integer", "minimum": 0 },
        "iocRefreshTTL": { "type": "integer", "minimum": 0 },
        "staleTTL": { "type": "integer", "minimum": 0 },
        "virusTotalApiKey": { "type": ["string", "null"] }
      }
    },
    "learning": {
      "type": "object",
      "description": "Adaptive learning / auto-tune configuration.",
      "properties": {
        "enabled": { "type": "boolean" },
        "autoTuneThreshold": { "type": "integer", "minimum": 1 }
      }
    },
    "arSubscriptions": {
      "type": "object",
      "description": "Phase D — AR measure ingest subscription config. Absent or enabled:false = Phase D disabled.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master kill switch. false (default) = Phase D disabled entirely."
        },
        "cursorPath": {
          "type": "string",
          "description": "Filename (relative to stateDir) for last-processed JSONL offsets.",
          "default": "ar-ingest-cursor.json"
        },
        "maxNudgePerEvent": {
          "type": "number",
          "description": "Absolute ceiling on any single AR-driven confidence delta magnitude.",
          "minimum": 0,
          "maximum": 0.02,
          "default": 0.005
        },
        "maxEventsPerScanner24h": {
          "type": "integer",
          "description": "Rate limit: max AR events applied per scanner per 24h.",
          "minimum": 0,
          "maximum": 100,
          "default": 10
        },
        "scanners": {
          "type": "object",
          "description": "Per-scanner subscription map. Keys must be A-I (AISLE scanner IDs).",
          "additionalProperties": false,
          "patternProperties": {
            "^[A-I]$": {
              "type": "object",
              "properties": {
                "domains": {
                  "type": "array",
                  "description": "AR domain subscriptions for this scanner.",
                  "items": {
                    "type": "object",
                    "required": ["domain", "polarity"],
                    "properties": {
                      "domain": {
                        "type": "string",
                        "description": "Must match a domain name in scripts/autoresearch/domains/.",
                        "minLength": 1
                      },
                      "polarity": {
                        "type": "string",
                        "description": "direct = metric improvement raises confidence; inverse = metric improvement lowers confidence.",
                        "enum": ["direct", "inverse"]
                      },
                      "weight": {
                        "type": "number",
                        "description": "Scales maxNudgePerEvent for this subscription. Default 1.0.",
                        "exclusiveMinimum": 0,
                        "maximum": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "performance": {
      "type": "object",
      "description": "Performance budget configuration.",
      "properties": {
        "evaluateBudgetMs": { "type": "integer", "minimum": 1 },
        "totalGateBudgetMs": { "type": "integer", "minimum": 1 },
        "bootTimeoutMs": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "definitions": {
    "tier": {
      "type": "string",
      "description": "Response tier. QUARANTINE is an action modifier, not a tier.",
      "enum": ["BLOCK", "WARN", "LOG"]
    },
    "exception": {
      "type": "object",
      "required": ["id", "scanner", "reason", "expiry"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "scanner": { "type": "string", "minLength": 1 },
        "tier": { "$ref": "#/definitions/tier" },
        "reason": { "type": "string", "minLength": 1 },
        "expiry": {
          "type": "string",
          "description": "ISO 8601 date string. Expired exceptions are ignored."
        }
      }
    }
  }
}
